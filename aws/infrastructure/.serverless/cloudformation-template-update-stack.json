                    "sqs:DeleteMessage",
                    "sqs:GetQueueAttributes"
                  ],
                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "EventQueue",
                        "Arn"
                      ]
                    }
                  ]
                }
              ]
            }
          }
        ],
