# Authentication
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/complaint_app

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8082,http://localhost:8083,http://localhost:8084

# Environment
NODE_ENV=development
PORT=3001

# Feature Flags — set to 'true' to enable
FEATURE_PROFILES_SUPABASE=true
FEATURE_COMPLAINTS_SUPABASE=true
FEATURE_QUICKNOTES_SUPABASE=true
FEATURE_ATTACHMENTS_S3=false
FEATURE_REALTIME_WS=false

#  Dev Mode - Skip authentication for testing
SKIP_AUTH=false