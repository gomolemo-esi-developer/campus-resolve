{
  "name": "proxy-server",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run start:api:all\" \"npm run dev:proxy\"",
    "dev:backend": "node src/backend-server.js",
    "dev:proxy": "node src/server.js",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:proxy\"",
    "start:api": "node src/backend-server.js",
    "start:api:voice": "node src/backend-server.js",
    "start:api:resolve": "node src/backend-resolve.js",
    "start:api:admin": "node src/backend-admin.js",
    "start:api:admin:supabase": "node src/backend-admin-supabase.js",
    "start:api:all": "concurrently \"npm run start:api:voice\" \"npm run start:api:resolve\" \"npm run start:api:admin\"",
    "start:proxy": "node src/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.370.0",
    "@aws-sdk/client-s3": "^3.370.0",
    "@aws-sdk/s3-request-presigner": "^3.370.0",
    "@supabase/supabase-js": "^2.99.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "http-proxy": "^1.18.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^30.3.0",
    "node": "^18.0.0",
    "supertest": "^7.2.2"
  }
}
